{
  "name": "homestoq",
  "private": true,
  "scripts": {
    "dev": "docker compose up",
    "dev:local": "dotnet build src/HomeStoq.Shared && concurrently --names \"API,SCRAPER\" --prefix-colors \"blue,green\" \"npm run api:local\" \"npm run scraper:local\"",
    "api:local": "dotnet build && dotnet run --project src/HomeStoq.App",
    "scraper:local": "dotnet run --project src/HomeStoq.Plugins/HomeStoq.Plugins.GoogleKeepScraper",
    "docker:build": "docker compose build",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v && npm run clean",
    "clean": "node scripts/clean.js",
    "setup": "node scripts/setup.js",
    "playwright:install": "dotnet exec --project src/HomeStoq.Plugins/HomeStoq.Plugins.GoogleKeepScraper Microsoft.Playwright.dll install",
    "help": "node scripts/help.js"
  },
  "devDependencies": {
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.2",
    "gradient-string": "^2.0.2"
  }
}
