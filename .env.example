# HomeStoq Environment Configuration
# 
# Copy this file to .env and fill in your actual values
# .env is gitignored and should never be committed

# =============================================================================
# AI Provider API Keys - BOTH REQUIRED when using OpenRouter
# =============================================================================
# 
# IMPORTANT: Receipt scanning (OCR) ALWAYS uses Gemini regardless of provider
# setting. When Provider=OpenRouter in config.ini, you MUST set BOTH keys.
#
# Architecture:
#   - Vision (receipt scanning): Always Gemini (for multimodal/OCR support)
#   - General (chat/voice/shopping): Configurable (Gemini or OpenRouter)

# Gemini API Key - REQUIRED for receipt scanning (OCR/vision)
# This is MANDATORY even when Provider=OpenRouter
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter API Key - REQUIRED when Provider=OpenRouter
# Not needed when Provider=Gemini (Gemini key handles everything)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# =============================================================================
# Google Account (Optional - for Google Keep scraper)
# =============================================================================
# WARNING: 2FA does not work well with the scraper
# Consider using an App Password if you have 2FA enabled
#GOOGLE_USERNAME=your-email@gmail.com
#GOOGLE_PASSWORD=your-password-or-app-password
